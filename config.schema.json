{
  "pluginAlias": "iAquaLink",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "Homebridge plugin for Jandy/Zodiac iAquaLink pool & spa controllers.",
  "footerDisplay": "For help, visit: https://github.com/your-username/homebridge-iaqualink",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "iAquaLink",
        "required": true
      },
      "username": {
        "title": "iAquaLink Username (Email)",
        "type": "string",
        "required": true,
        "format": "email",
        "placeholder": "your@email.com",
        "description": "The email address you use to log into the iAquaLink app."
      },
      "password": {
        "title": "iAquaLink Password",
        "type": "string",
        "required": true,
        "x-schema-form": {
          "type": "password"
        },
        "description": "Your iAquaLink account password."
      },
      "pollingInterval": {
        "title": "Polling Interval (seconds)",
        "type": "integer",
        "default": 30,
        "minimum": 10,
        "maximum": 300,
        "description": "How often (in seconds) to poll the iAquaLink API for device state updates."
      },
      "temperatureUnit": {
        "title": "Temperature Unit",
        "type": "string",
        "default": "F",
        "oneOf": [
          { "title": "Fahrenheit (°F)", "enum": ["F"] },
          { "title": "Celsius (°C)", "enum": ["C"] }
        ],
        "description": "Override the temperature unit. If not set, the unit is detected automatically from the iAquaLink controller."
      },
      "auxiliaryDevices": {
        "title": "Auxiliary Device Overrides",
        "type": "array",
        "description": "Optionally override the HomeKit service type for individual auxiliary outputs. Useful when iAquaLink cannot determine if an aux is a fan, valve, or switch.",
        "items": {
          "type": "object",
          "properties": {
            "aux": {
              "title": "Aux Number",
              "type": "string",
              "description": "The auxiliary output number (e.g. \"1\" for Aux 1, \"2\" for Aux 2).",
              "required": true
            },
            "type": {
              "title": "Device Type",
              "type": "string",
              "default": "switch",
              "oneOf": [
                { "title": "Switch (generic on/off)", "enum": ["switch"] },
                { "title": "Fan", "enum": ["fan"] },
                { "title": "Valve (water feature)", "enum": ["valve"] }
              ],
              "required": true
            },
            "name": {
              "title": "Display Name Override",
              "type": "string",
              "description": "Optional. Override the name shown in the Home app for this aux device."
            },
            "valveType": {
              "title": "Valve Type",
              "type": "string",
              "default": "generic",
              "description": "Only used when type is set to Valve.",
              "oneOf": [
                { "title": "Generic Valve", "enum": ["generic"] },
                { "title": "Irrigation", "enum": ["irrigation"] },
                { "title": "Shower Head", "enum": ["shower"] },
                { "title": "Water Faucet", "enum": ["faucet"] }
              ]
            }
          }
        }
      }
    }
  },
  "layout": [
    {
      "type": "fieldset",
      "title": "Account",
      "items": ["username", "password"]
    },
    {
      "type": "fieldset",
      "title": "Options",
      "expandable": true,
      "items": ["pollingInterval", "temperatureUnit"]
    },
    {
      "type": "fieldset",
      "title": "Auxiliary Device Overrides",
      "expandable": true,
      "items": [
        {
          "key": "auxiliaryDevices",
          "type": "array",
          "items": [
            "auxiliaryDevices[].aux",
            "auxiliaryDevices[].type",
            "auxiliaryDevices[].name",
            "auxiliaryDevices[].valveType"
          ]
        }
      ]
    }
  ]
}
